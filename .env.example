# Copy this file to .env and fill in your key. Never commit .env to git.
# Groq (free tier at console.groq.com) — enables LLM answer synthesis:
GROQ_API_KEY=gsk_your_key_here

# Optional: override the model (default: llama-3.3-70b-versatile)
# PLANTBRAIN_LLM_MODEL=llama-3.3-70b-versatile

# Alternative provider (takes precedence if set):
# ANTHROPIC_API_KEY=sk-ant-...
